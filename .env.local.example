# ── Supabase ────────────────────────────────────────────────
# Find these at: supabase.com > Your Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...YOUR_SERVICE_ROLE_KEY

# ── Cloudinary ──────────────────────────────────────────────
# Find these at: cloudinary.com > Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_cloudinary_secret

# ── Admin portal ────────────────────────────────────────────
# Choose any long random password — you type this to log into /admin
ADMIN_SECRET=choose_a_long_random_string_here

# ── WhatsApp ─────────────────────────────────────────────────
# Your number with country code (91 for India), no + sign
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210
